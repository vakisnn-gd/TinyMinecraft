{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "TinyCraftServer",
      "request": "launch",
      "mainClass": "TinyCraftServer",
      "projectName": "MinecraftTest"
    },
    {
      "type": "java",
      "name": "TinyCraft",
      "request": "launch",
      "mainClass": "TinyCraft",
      "cwd": "${workspaceFolder}",
      "classPaths": [
        "${workspaceFolder}/out",
        "${workspaceFolder}/lib/lwjgl-3.3.3.jar",
        "${workspaceFolder}/lib/lwjgl-3.3.3-natives-windows.jar",
        "${workspaceFolder}/lib/lwjgl-glfw-3.3.3.jar",
        "${workspaceFolder}/lib/lwjgl-glfw-3.3.3-natives-windows.jar",
        "${workspaceFolder}/lib/lwjgl-openal-3.3.3.jar",
        "${workspaceFolder}/lib/lwjgl-openal-3.3.3-natives-windows.jar",
        "${workspaceFolder}/lib/lwjgl-opengl-3.3.3.jar",
        "${workspaceFolder}/lib/lwjgl-opengl-3.3.3-natives-windows.jar",
        "${workspaceFolder}/lib/lwjgl-stb-3.3.3.jar",
        "${workspaceFolder}/lib/lwjgl-stb-3.3.3-natives-windows.jar"
      ],
      "vmArgs": "-Dfile.encoding=UTF-8",
      "console": "integratedTerminal",
      "preLaunchTask": "compile TinyCraft"
    }
  ]
}
